# =============================================================
# Purposeful Living — Environment Variables
# Copy to .env for local development. Never commit .env.
# =============================================================

# ── Supabase ─────────────────────────────────────────────────
# Project URL from: Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public anon key (safe for client-side use)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Monnify (PENDING: replace with real credentials) ─────────
# Sandbox:  https://sandbox.monnify.com
# Production: https://api.monnify.com
MONNIFY_BASE_URL=https://sandbox.monnify.com

# From Monnify merchant dashboard → Settings → API keys
MONNIFY_API_KEY=PENDING_MONNIFY_API_KEY
MONNIFY_SECRET_KEY=PENDING_MONNIFY_SECRET_KEY

# From Monnify merchant dashboard → Settlement accounts
MONNIFY_CONTRACT_CODE=PENDING_MONNIFY_CONTRACT_CODE

# Where Monnify redirects the customer after payment
# Must be a public URL registered in Monnify dashboard
MONNIFY_REDIRECT_URL=https://your-domain.vercel.app/order-confirmation.html

# ── Resend (PENDING: verify sending domain) ──────────────────
# API key from resend.com dashboard
RESEND_API_KEY=PENDING_RESEND_API_KEY

# Verified sender address (must match your Resend domain)
RESEND_FROM=Purposeful Living <orders@PENDING_VERIFIED_DOMAIN>

# Admin notification recipient
ADMIN_EMAIL=PENDING_ADMIN_EMAIL

# ── E-book (PENDING: upload file to Supabase Storage) ────────
# Private bucket name in Supabase Storage
EBOOK_BUCKET=ebooks

# Path to the e-book file within the bucket
EBOOK_STORAGE_PATH=PENDING_EBOOK_FILENAME.pdf

# Token expiry in seconds (default: 48 hours)
EBOOK_LINK_TTL_SECONDS=172800

# Maximum download attempts per token
EBOOK_MAX_DOWNLOADS=5

# ── Sales configuration ───────────────────────────────────────
# Controls physical copy availability: AVAILABLE | WAITLIST | SOLD_OUT
PHYSICAL_SALES_MODE=WAITLIST

# ── Application ──────────────────────────────────────────────
# Base URL of deployed site (used for building absolute links in emails)
APP_URL=https://your-domain.vercel.app

# Node environment
NODE_ENV=development

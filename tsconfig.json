{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": ".vercel/output",
    "rootDir": "."
  },
  "include": ["api/**/*", "lib/**/*", "tests/**/*"],
  "exclude": ["node_modules", ".vercel"]
}
